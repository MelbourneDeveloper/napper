              "value": "["
            },
            {
              "type": "STRING",
              "value": "request"
            },
            {
              "type": "STRING",
              "value": "."
            },
            {
              "type": "STRING",
              "value": "headers"
            },
            {
              "type": "STRING",
              "value": "]"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "["
            },
            {
              "type": "STRING",
