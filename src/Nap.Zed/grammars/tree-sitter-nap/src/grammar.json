        },
        {
          "type": "STRING",
          "value": "exists"
        }
      ]
    },
    "assertion_contains": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "key"
        },
        {
          "type": "STRING",
          "value": "contains"
        },
        {
          "type": "SYMBOL",
          "name": "assertion_value"
        }
      ]
    },
    "assertion_matches": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "key"
        },
        {
          "type": "STRING",
          "value": "matches"
        },
        {
          "type": "SYMBOL",
          "name": "assertion_value"
        }
      ]
    },
    "assertion_lt": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
